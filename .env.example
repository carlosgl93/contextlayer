MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_BATCH_SIZE=20

# Firebase project: sg-cloud-cefee
# IMPORTANT: this project has existing Cloud Functions and Firestore collections — do not drop or modify them
FIREBASE_PROJECT_ID=sg-cloud-cefee
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=sg-cloud-cefee.firebaseapp.com
FIREBASE_STORAGE_BUCKET=sg-cloud-cefee.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=250058155586
FIREBASE_APP_ID=your-firebase-app-id

# Firebase Admin SDK — download from Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the JSON content as a single-line base64 string:
# cat serviceAccount.json | base64 | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT=

rules_version = '2';

// ContextLayer Firestore security rules.
//
// V1 stance: all reads and writes to application data go through
// server routes backed by the Firebase Admin SDK. Admin SDK bypasses
// these rules entirely, so the source of truth for authorization is
// the server-side code in `src/b2b/` and `src/routes/`.
//
// This rules file is defensive: it denies direct client SDK access to
// sensitive paths so a future client integration or an accidental
// client-side configuration cannot read or write tenant/user data
// without going through the validated server endpoints.
//
// If V2 introduces a client SDK for tenant admin or user-facing B2C
// reads, replace the unconditional deny with custom-claim gates here.
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny. Every collection must opt in below.
    match /{document=**} {
      allow read, write: if false;
    }

    // Track 1: B2C user profile, conversations, and siteAccess.
    // Direct client access denied. Read/write via admin SDK in
    // src/routes/ and src/firestore/. The user-centric siteAccess
    // list endpoint (GET /api/v1/user/access) goes through admin SDK
    // after Firebase ID token verification.
    match /users/{uid}/{document=**} {
      allow read, write: if false;
    }

    // Track 2/4: B2B tenant namespace. Per-tenant isolation: rules
    // cannot enforce cross-tenant boundaries on path traversal (the
    // tenantId in the path is the boundary), but denying all client
    // access forces every read/write through admin SDK routes that
    // validate the tenant API key and visitor scope server-side.
    match /b2bTenants/{tenantId}/{document=**} {
      allow read, write: if false;
    }

    // Rate limit counters per tenant. Same deny-all stance; admin
    // SDK in src/b2b/chat-history.ts increments these on each chat.
    match /rateLimits/{document=**} {
      allow read, write: if false;
    }
  }
}